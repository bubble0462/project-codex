  99:User_App/app_display.c **** static void App_Display_FormatPrimary(const MeasureResult_t *result, char *buf, uint32_t len)
 100:User_App/app_display.c **** {
 101:User_App/app_display.c ****     char val[20];
 102:User_App/app_display.c **** 
 103:User_App/app_display.c ****     if ((result == NULL) || (result->valid == 0u)) {
 104:User_App/app_display.c ****         snprintf(buf, len, "-- Measuring --");
 105:User_App/app_display.c ****         return;
 106:User_App/app_display.c ****     }
 107:User_App/app_display.c **** 
 108:User_App/app_display.c ****     switch (result->comp_type) {
 109:User_App/app_display.c ****     case COMP_RESISTOR:
 110:User_App/app_display.c ****         App_Display_FormatRes(result->primary_value, val, sizeof(val));
 111:User_App/app_display.c ****         snprintf(buf, len, "R %s", val);
 112:User_App/app_display.c ****         break;
 113:User_App/app_display.c ****     case COMP_CAPACITOR:
 114:User_App/app_display.c ****         App_Display_FormatCap(result->primary_value, val, sizeof(val));
 115:User_App/app_display.c ****         snprintf(buf, len, "C %s", val);
 116:User_App/app_display.c ****         break;
 117:User_App/app_display.c ****     case COMP_INDUCTOR:
 118:User_App/app_display.c ****         App_Display_FormatInd(result->primary_value, val, sizeof(val));
 119:User_App/app_display.c ****         snprintf(buf, len, "L %s", val);
 120:User_App/app_display.c ****         break;
 121:User_App/app_display.c ****     default:
 122:User_App/app_display.c ****         snprintf(buf, len, "Unknown");
 123:User_App/app_display.c ****         break;
 124:User_App/app_display.c ****     }
 125:User_App/app_display.c **** }
