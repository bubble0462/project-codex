  54:User_App/app_display.c **** static void App_Display_FormatRes(float value, char *buf, uint32_t len)
  55:User_App/app_display.c **** {
  56:User_App/app_display.c ****     float absv = fabsf(value);
  57:User_App/app_display.c **** 
  58:User_App/app_display.c ****     if (absv >= 1e6f) {
  59:User_App/app_display.c ****         snprintf(buf, len, "%.3fMR", value / 1e6f);
  60:User_App/app_display.c ****     } else if (absv >= 1e3f) {
  61:User_App/app_display.c ****         snprintf(buf, len, "%.3fkR", value / 1e3f);
  62:User_App/app_display.c ****     } else if (absv >= 1.0f) {
  63:User_App/app_display.c ****         snprintf(buf, len, "%.3fR", value);
  64:User_App/app_display.c ****     } else {
  65:User_App/app_display.c ****         snprintf(buf, len, "%.2fmR", value * 1e3f);
  66:User_App/app_display.c ****     }
  67:User_App/app_display.c **** }
  68:User_App/app_display.c **** 
  69:User_App/app_display.c **** static void App_Display_FormatCap(float value, char *buf, uint32_t len)
  70:User_App/app_display.c **** {
  71:User_App/app_display.c ****     float absv = fabsf(value);
  72:User_App/app_display.c **** 
  73:User_App/app_display.c ****     if (absv >= 1e-3f) {
  74:User_App/app_display.c ****         snprintf(buf, len, "%.3fmF", value * 1e3f);
  75:User_App/app_display.c ****     } else if (absv >= 1e-6f) {
  76:User_App/app_display.c ****         snprintf(buf, len, "%.3fuF", value * 1e6f);
  77:User_App/app_display.c ****     } else if (absv >= 1e-9f) {
  78:User_App/app_display.c ****         snprintf(buf, len, "%.3fnF", value * 1e9f);
  79:User_App/app_display.c ****     } else {
  80:User_App/app_display.c ****         snprintf(buf, len, "%.2fpF", value * 1e12f);
  81:User_App/app_display.c ****     }
  82:User_App/app_display.c **** }
