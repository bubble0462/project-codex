 127:User_App/app_display.c **** static void App_Display_BatteryBar(float vbat, char *buf, uint32_t len)
 128:User_App/app_display.c **** {
 129:User_App/app_display.c ****     int pct = (int)(((vbat - 3.5f) / (4.2f - 3.5f)) * 100.0f);
 130:User_App/app_display.c ****     int bars;
 131:User_App/app_display.c **** 
 132:User_App/app_display.c ****     if (pct < 0) {
 133:User_App/app_display.c ****         pct = 0;
 134:User_App/app_display.c ****     }
 135:User_App/app_display.c ****     if (pct > 100) {
 136:User_App/app_display.c ****         pct = 100;
 137:User_App/app_display.c ****     }
 138:User_App/app_display.c **** 
 139:User_App/app_display.c ****     bars = pct / 20;
 140:User_App/app_display.c ****     snprintf(buf,
 141:User_App/app_display.c ****              len,
 142:User_App/app_display.c ****              "[%c%c%c%c%c]",
ARM GAS  C:\Users\bubble\AppData\Local\Temp\cc51e8AY.s 			page 6


 143:User_App/app_display.c ****              (bars >= 1) ? '#' : '.',
 144:User_App/app_display.c ****              (bars >= 2) ? '#' : '.',
 145:User_App/app_display.c ****              (bars >= 3) ? '#' : '.',
 146:User_App/app_display.c ****              (bars >= 4) ? '#' : '.',
 147:User_App/app_display.c ****              (bars >= 5) ? '#' : '.');
 148:User_App/app_display.c **** }
